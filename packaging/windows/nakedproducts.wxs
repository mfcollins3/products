<?xml version="1.0" encoding="UTF-8"?>
<!--
Copyright 2026 Michael F. Collins, III
Licensed under the Naked Products Source-Available Temporary License
See LICENSE.md for license terms

Build with:
  wix build nakedproducts.wxs -d Version=<version> -arch x64 -o nakedproducts-<version>-windows-x64.msi
  wix build nakedproducts.wxs -d Version=<version> -arch arm64 -o nakedproducts-<version>-windows-arm64.msi

TODO: Replace UpgradeCode GUID with a permanent value generated by the
product owner before publishing the first public release. The placeholder
GUID below must never ship to end users.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Naked Products"
    Manufacturer="Michael F. Collins, III"
    Version="$(var.Version)"
    UpgradeCode="00000000-0000-0000-0000-000000000001"
    Scope="perMachine"
    InstallerVersion="500"
  >
    <!-- Remove any earlier version before installing the new one. -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
    />

    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata. -->
    <Property Id="ARPURLINFOABOUT"
              Value="https://github.com/mfcollins3/products" />
    <Property Id="ARPHELPLINK"
              Value="https://github.com/mfcollins3/products/issues" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <Feature Id="Complete" Title="Naked Products" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <!--
      Install to %ProgramFiles%\NakedProducts on x64 and ARM64.
      WiX maps ProgramFiles64Folder to the correct location based on
      the -arch flag passed at build time.
    -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="NakedProducts" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable">
        <!--
          Source path is relative to the .wxs file at build time.
          The release workflow copies the downloaded binary alongside
          this file before running wix build.
        -->
        <File
          Id="nakedproducts.exe"
          Source="nakedproducts.exe"
          KeyPath="yes"
        />

        <!--
          Append the install directory to the system PATH so that
          `nakedproducts` is available from any command prompt.
        -->
        <Environment
          Id="AddToSystemPath"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="yes"
        />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
