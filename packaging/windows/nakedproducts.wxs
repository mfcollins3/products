<?xml version="1.0" encoding="UTF-8"?>
<!--
Copyright 2026 Michael F. Collins, III
Licensed under the Naked Products Source-Available Temporary License
See LICENSE.md for license terms

Build with:
  wix build nakedproducts.wxs -d Version=<version> -arch x64 -o nakedproducts-<version>-windows-x64.msi
  wix build nakedproducts.wxs -d Version=<version> -arch arm64 -o nakedproducts-<version>-windows-arm64.msi

Per-user installation (default, no elevation required):
  msiexec /i nakedproducts.msi
  Installs to: %LOCALAPPDATA%\Programs\NakedProducts
  Adds install directory to the current user's PATH.

Per-machine installation (requires elevation):
  msiexec /i nakedproducts.msi ALLUSERS=1
  Installs to: %ProgramFiles%\NakedProducts
  Adds install directory to the system PATH.

NOTE: MajorUpgrade detection is scope-specific. Upgrading from a
per-user install to per-machine (or the reverse) will install a new
instance rather than remove the prior one. Users should uninstall the
existing installation before switching scopes.

TODO: Replace UpgradeCode GUID with a permanent value generated by the
product owner before publishing the first public release. The placeholder
GUID below must never ship to end users.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Naked Products"
    Manufacturer="Michael F. Collins, III"
    Version="$(var.Version)"
    UpgradeCode="34388A03-36B7-4352-8F74-70189DB2EADA"
    InstallerVersion="500"
  >
    <!--
      Default to per-user installation (no elevation required).
      The user may pass ALLUSERS=1 on the command line to install
      for all users on the machine (requires elevation):

        msiexec /i nakedproducts.msi ALLUSERS=1

      Secure="yes" allows a non-administrator to supply this property
      so that per-user remains the baseline without special privileges.
    -->
    <Property Id="ALLUSERS" Secure="yes" Value="" />

    <!--
      Per-user default: %LOCALAPPDATA%\Programs\NakedProducts.
      Overridden to %ProgramFiles%\NakedProducts when ALLUSERS=1.
    -->
    <SetProperty
      Id="INSTALLFOLDER"
      Value="[ProgramFiles64Folder]NakedProducts"
      After="AppSearch"
      Condition="ALLUSERS = &quot;1&quot;"
    />

    <!-- Remove any earlier version in the same scope before installing. -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
    />

    <MediaTemplate EmbedCab="yes" />

    <!-- Add/Remove Programs metadata. -->
    <Property Id="ARPURLINFOABOUT"
              Value="https://github.com/mfcollins3/products" />
    <Property Id="ARPHELPLINK"
              Value="https://github.com/mfcollins3/products/issues" />
    <Property Id="ARPNOREPAIR" Value="1" />

    <Feature Id="Complete" Title="Naked Products" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
    </Feature>
  </Package>

  <Fragment>
    <!--
      Default install location for per-user installs:
        %LOCALAPPDATA%\Programs\NakedProducts

      The SetProperty above overrides INSTALLFOLDER to ProgramFiles64Folder
      when ALLUSERS=1 (per-machine). WiX maps ProgramFiles64Folder to the
      correct location for the target architecture (-arch x64 or arm64).
    -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="UserProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="NakedProducts" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">

      <!--
        The main executable.
        Source path is relative to the .wxs file at build time.
        The release workflow copies the downloaded binary alongside
        this file before running wix build.
      -->
      <Component Id="MainExecutable">
        <File
          Id="nakedproducts.exe"
          Source="nakedproducts.exe"
          KeyPath="yes"
        />
      </Component>

      <!--
        Per-user PATH entry — installed only in per-user mode (ALLUSERS="").
        Adds INSTALLFOLDER to the current user's PATH without elevation.
        Registry key is the KeyPath so the component survives repair.
      -->
      <Component
        Id="UserPathEntry"
        Condition="NOT ALLUSERS = &quot;1&quot;"
      >
        <RegistryValue
          Root="HKCU"
          Key="Software\MFCollins3\NakedProducts"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes"
        />
        <Environment
          Id="AddToUserPath"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="no"
        />
      </Component>

      <!--
        Per-machine PATH entry — installed only when ALLUSERS=1.
        Adds INSTALLFOLDER to the system PATH (requires elevation).
        Registry key is the KeyPath so the component survives repair.
      -->
      <Component
        Id="SystemPathEntry"
        Condition="ALLUSERS = &quot;1&quot;"
      >
        <RegistryValue
          Root="HKLM"
          Key="Software\MFCollins3\NakedProducts"
          Name="Installed"
          Type="integer"
          Value="1"
          KeyPath="yes"
        />
        <Environment
          Id="AddToSystemPath"
          Name="PATH"
          Value="[INSTALLFOLDER]"
          Permanent="no"
          Part="last"
          Action="set"
          System="yes"
        />
      </Component>

    </ComponentGroup>
  </Fragment>
</Wix>
